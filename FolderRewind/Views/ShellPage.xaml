<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FolderRewind.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    KeyboardAcceleratorPlacementMode="Hidden">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Image Grid.RowSpan="3"
               Source="{x:Bind ViewModel.SponsorBackgroundImageSource, Mode=OneWay}"
               Stretch="{x:Bind ViewModel.SponsorBackgroundStretch, Mode=OneWay}"
               Opacity="{x:Bind ViewModel.SponsorBackgroundOpacity, Mode=OneWay}"
               Visibility="{x:Bind ViewModel.IsSponsorBackgroundVisible, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}" />
        <Border Grid.RowSpan="3"
                Background="{x:Bind ViewModel.SponsorBackgroundOverlayBrush, Mode=OneWay}"
                Opacity="{x:Bind ViewModel.SponsorBackgroundOverlayOpacity, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.IsSponsorBackgroundVisible, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}" />

        <Border x:Name="AppTitleBar"
                Grid.Row="0"
                Height="44"
                Background="Transparent"
            Padding="12,0,12,0"
            KeyboardAcceleratorPlacementMode="Hidden">
            <Grid ColumnSpacing="10" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <FontIcon Glyph="{x:Bind ViewModel.TitleIconGlyph, Mode=OneWay}" FontSize="16" Opacity="0.9" />
                <TextBlock Grid.Column="1"
                           Text="{x:Bind ViewModel.TitleText, Mode=OneWay}"
                           Style="{ThemeResource BodyStrongTextBlockStyle}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>

        <!-- 全局 InfoBar 通知区域 -->
        <InfoBar x:Name="GlobalInfoBar"
                 Grid.Row="1"
                 IsOpen="False"
                 IsClosable="True"
                 Margin="12,0,12,8"
                 Closed="GlobalInfoBar_Closed" />

        <NavigationView x:Name="NavView"
                        Grid.Row="2"
                        Background="Transparent"
                        x:Uid="ShellPage_Header"
                        PaneDisplayMode="Auto"
                        ExpandedModeThresholdWidth="1120"
                        IsSettingsVisible="True" 
                        OpenPaneLength="{x:Bind Settings.NavPaneWidth, Mode=OneWay}"
                        IsBackButtonVisible="Visible"
                        DisplayModeChanged="NavView_DisplayModeChanged"
                        SelectionChanged="NavView_SelectionChanged"
                        Loaded="NavView_Loaded"
                        PaneOpened="NavView_PaneOpened"
                        PaneClosed="NavView_PaneClosed"
                BackRequested="NavView_BackRequested"
                KeyboardAcceleratorPlacementMode="Hidden">

            <NavigationView.MenuItems>
                <NavigationViewItem x:Uid="ShellPage_NavHome" Tag="Home">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Home"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Uid="ShellPage_NavManager" Tag="Manager">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Manage"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Name="TasksNavItem" x:Uid="ShellPage_NavTasks" Tag="Tasks">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Copy"/>
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.InfoBadge>
                        <InfoBadge x:Name="TasksRunningInfoBadge" Visibility="Collapsed"/>
                    </NavigationViewItem.InfoBadge>
                </NavigationViewItem>

                <NavigationViewItem x:Uid="ShellPage_NavHistory" Tag="History">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Clock"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Uid="ShellPage_NavLogs" Tag="Logs">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Library"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" CacheSize="10" />
        </NavigationView>
    </Grid>
</Page>
