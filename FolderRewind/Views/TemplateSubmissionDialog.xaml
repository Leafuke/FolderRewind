<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="FolderRewind.Views.TemplateSubmissionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Uid="TemplateSubmissionDialog"
    DefaultButton="Primary"
    Style="{StaticResource DefaultContentDialogStyle}">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMinWidth">520</x:Double>
        <x:Double x:Key="ContentDialogMaxWidth">860</x:Double>
    </ContentDialog.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid MinWidth="760" MaxWidth="980" MinHeight="420" ColumnSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*" />
                <ColumnDefinition Width="0.95*" />
            </Grid.ColumnDefinitions>

            <InfoBar x:Name="FeedbackBar"
                     Grid.Row="0"
                     Grid.ColumnSpan="2"
                     IsOpen="False"
                     IsClosable="True" />

            <StackPanel Grid.Row="1" Grid.Column="0" Spacing="12">
                <TextBlock x:Uid="TemplateSubmissionDialog_PrepareSection"
                           Style="{ThemeResource SubtitleTextBlockStyle}" />
                <TextBlock x:Uid="Template_Submission_PrepareHint"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap" />

                <TextBlock x:Uid="Template_Submission_SelectTemplate"
                           Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <ComboBox x:Name="TemplateComboBox"
                          HorizontalAlignment="Stretch"
                          SelectionChanged="OnTemplateSelectionChanged" />

                <Border Padding="12"
                        CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock x:Uid="TemplateSubmissionDialog_SelectedTemplate"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock x:Name="TemplateMetaTextBlock"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <TextBlock x:Uid="Template_Submission_GameNameHeader"
                           Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <TextBox x:Name="GameNameBox" />
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="12">
                <TextBlock x:Uid="TemplateSubmissionDialog_GitHubSection"
                           Style="{ThemeResource SubtitleTextBlockStyle}" />
                <TextBlock x:Uid="TemplateSubmissionDialog_GitHubHint"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap" />

                <Border Padding="12"
                        CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="10">
                        <TextBlock x:Uid="TemplateSubmissionDialog_GitHubStatus"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock x:Name="GitHubAuthStatusTextBlock"
                                   TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Uid="TemplateSubmissionDialog_RefreshAuth"
                                    Click="OnRefreshGitHubStatusClick" />
                            <Button x:Uid="SettingsPage_GitHubSignOut"
                                    Click="OnGitHubSignOutClick" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</ContentDialog>
