<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="FolderRewind.Views.TemplateManagerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FolderRewind.Views"
    xmlns:models="using:FolderRewind.Models"
    x:Uid="TemplateManagerDialog"
    CloseButtonText="Close"
    DefaultButton="Close"
    Style="{StaticResource DefaultContentDialogStyle}">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMinWidth">500</x:Double>
        <x:Double x:Key="ContentDialogMaxWidth">1380</x:Double>
    </ContentDialog.Resources>

    <Grid MinWidth="560" MaxWidth="1280" Height="720" ColumnSpacing="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Spacing="10">
            <TextBlock x:Uid="TemplateManagerDialog_ListHeader" Style="{ThemeResource SubtitleTextBlockStyle}" />
            <TextBox x:Name="SearchBox"
                     x:Uid="TemplateManagerDialog_Search"
                     TextChanged="OnSearchTextChanged" />

            <ListView x:Name="TemplateListView"
                      Height="600"
                      SelectionMode="Single"
                      ItemsSource="{x:Bind TemplatesView, Mode=OneWay}"
                      SelectionChanged="OnTemplateSelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:ConfigTemplate">
                        <StackPanel Spacing="2" Padding="0,6,0,6">
                            <TextBlock Text="{x:Bind Name}" Style="{ThemeResource BodyStrongTextBlockStyle}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{x:Bind Author}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{x:Bind BaseConfigType}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <TextBlock x:Uid="TemplateManagerDialog_EmptyList"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Visibility="{x:Bind IsTemplateListEmpty, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}" />
        </StackPanel>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="0,0,8,16">
            <StackPanel Spacing="12">
                <TextBlock x:Uid="TemplateManagerDialog_DetailHeader" Style="{ThemeResource SubtitleTextBlockStyle}" />

                <InfoBar x:Name="FeedbackBar" IsOpen="False" IsClosable="True" />

                <TextBox x:Name="TemplateNameBox" x:Uid="TemplateManagerDialog_Name" IsEnabled="{x:Bind HasSelection, Mode=OneWay}" />
                <TextBox x:Name="TemplateAuthorBox" x:Uid="TemplateManagerDialog_Author" IsEnabled="{x:Bind HasSelection, Mode=OneWay}" />
                <TextBox x:Name="TemplateDescriptionBox"
                         x:Uid="TemplateManagerDialog_Description"
                         AcceptsReturn="True"
                         MinHeight="84"
                         TextWrapping="Wrap"
                         IsEnabled="{x:Bind HasSelection, Mode=OneWay}" />

                <TextBlock x:Name="TemplateMetaText"
                           x:Uid="TemplateManagerDialog_TemplateMeta"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap" />

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Uid="TemplateManagerDialog_Save"
                            Click="OnSaveTemplateClick"
                            IsEnabled="{x:Bind HasSelection, Mode=OneWay}" />
                    <Button x:Uid="TemplateManagerDialog_Duplicate"
                            Click="OnDuplicateTemplateClick"
                            IsEnabled="{x:Bind HasSelection, Mode=OneWay}" />
                    <Button x:Uid="TemplateManagerDialog_Delete"
                            Click="OnDeleteTemplateClick"
                            IsEnabled="{x:Bind HasSelection, Mode=OneWay}" />
                    <Button x:Uid="TemplateManagerDialog_Export"
                            Click="OnExportTemplateClick"
                            IsEnabled="{x:Bind HasSelection, Mode=OneWay}" />
                </StackPanel>

                <Border x:Name="DeleteConfirmPanel"
                        CornerRadius="8"
                        Padding="10"
                        Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                        Visibility="Collapsed">
                    <StackPanel Spacing="10">
                        <TextBlock x:Name="DeleteConfirmText" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Uid="TemplateManagerDialog_DeleteConfirmYes" Click="OnConfirmDeleteTemplateClick" />
                            <Button x:Uid="TemplateManagerDialog_DeleteConfirmNo" Click="OnCancelDeleteTemplateClick" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Padding="12"
                        CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="10">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Uid="TemplateManagerDialog_PathRulesHeader" Style="{ThemeResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Button x:Uid="TemplateManagerDialog_AddRule"
                                        Click="OnAddRuleClick"
                                        IsEnabled="{x:Bind HasSelection, Mode=OneWay}" />
                                <Button x:Uid="TemplateManagerDialog_SaveRules"
                                        Click="OnSaveRulesClick"
                                        IsEnabled="{x:Bind HasSelection, Mode=OneWay}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock x:Uid="TemplateManagerDialog_PathRulesHint"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap" />

                        <ItemsControl ItemsSource="{x:Bind EditablePathRules, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:EditableTemplateRuleItem">
                                    <Border Margin="0,0,0,10"
                                            Padding="10"
                                            CornerRadius="8"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="8">
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Spacing="4">
                                                    <TextBlock x:Uid="TemplateManagerDialog_PathRuleName" />
                                                    <TextBox Text="{x:Bind Name, Mode=TwoWay}" />
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        x:Uid="TemplateManagerDialog_RemoveRule"
                                                        Tag="{x:Bind Id}"
                                                        Click="OnRemoveRuleClick" />
                                            </Grid>

                                            <StackPanel Spacing="4">
                                                <TextBlock x:Uid="TemplateManagerDialog_PathRulePath" />
                                                <TextBox Text="{x:Bind DisplayPath, Mode=TwoWay}" />
                                            </StackPanel>

                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <CheckBox x:Uid="TemplateManagerDialog_PathRuleAuto"
                                                          IsChecked="{x:Bind AutoAdd, Mode=TwoWay}" />
                                                <StackPanel Grid.Column="1" Spacing="4">
                                                    <TextBlock x:Uid="TemplateManagerDialog_PathRuleConfidence" />
                                                    <TextBox Text="{x:Bind ConfidenceText, Mode=TwoWay}" />
                                                </StackPanel>
                                            </Grid>

                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Uid="TemplateManagerDialog_NoRules"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Visibility="{x:Bind IsRuleListEmpty, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}" />
                    </StackPanel>
                </Border>

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Uid="TemplateManagerDialog_PreviewHeader" Style="{ThemeResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" />
                    <Button Grid.Column="1"
                            x:Uid="TemplateManagerDialog_RefreshPreview"
                            Click="OnRefreshPreviewClick"
                            IsEnabled="{x:Bind HasSelection, Mode=OneWay}" />
                </Grid>

                <TextBlock x:Name="PreviewSummaryText"
                           x:Uid="TemplateManagerDialog_PreviewSummary"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap" />

                <ItemsControl ItemsSource="{x:Bind PreviewItems, Mode=OneWay}"
                              IsEnabled="{x:Bind HasSelection, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:TemplateRulePreviewItem">
                            <Border Margin="0,0,0,10"
                                    Padding="10"
                                    CornerRadius="8"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{x:Bind RuleName}" Style="{ThemeResource BodyStrongTextBlockStyle}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{x:Bind Pattern}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{x:Bind StatusText}" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Text="{x:Bind MatchSummary}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <TextBlock Text="{x:Bind MarkerSummary}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                    <TextBlock Text="{x:Bind SamplePath}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock x:Uid="TemplateManagerDialog_NoPreview"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Visibility="{x:Bind IsPreviewEmpty, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ContentDialog>
